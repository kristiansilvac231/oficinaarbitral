# ─────────────────────────────────────────────
# BASE DE DATOS
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/oficinaarbitral?schema=public"

# ─────────────────────────────────────────────
# AUTENTICACIÓN (NextAuth.js / Auth.js)
# ─────────────────────────────────────────────
NEXTAUTH_URL="https://www.oficinaarbitral.cl"
NEXTAUTH_SECRET="[GENERAR CON: openssl rand -base64 32]"

# ─────────────────────────────────────────────
# FORMULARIO DE CONTACTO (Formspree)
# Obtener en: formspree.io → New Form → copiar el ID (ej: xyzabcde)
# ─────────────────────────────────────────────
NEXT_PUBLIC_FORMSPREE_FORM_ID="xyzabcde"

# ─────────────────────────────────────────────
# CONTACTO Y EMPRESA
# ─────────────────────────────────────────────
CONTACT_PHONE="+56 9 XXXX XXXX"
CONTACT_ADDRESS="Santiago, Región Metropolitana, Chile"

# ─────────────────────────────────────────────
# GOOGLE / SEO (variables públicas — prefijo NEXT_PUBLIC_)
# ─────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION="[CÓDIGO DE VERIFICACIÓN DE SEARCH CONSOLE]"

# ─────────────────────────────────────────────
# ZOOM (Fase 2 — dejar preparado)
# ─────────────────────────────────────────────
ZOOM_ACCOUNT_ID=""
ZOOM_CLIENT_ID=""
ZOOM_CLIENT_SECRET=""

# ─────────────────────────────────────────────
# ALMACENAMIENTO DE DOCUMENTOS (Fase 2)
# ─────────────────────────────────────────────
# Opción A: Vercel Blob
BLOB_READ_WRITE_TOKEN=""
# Opción B: AWS S3 / Cloudflare R2
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
STORAGE_BUCKET=""
STORAGE_ENDPOINT=""
